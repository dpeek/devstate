{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unpkg.com/devstate/schema/v1.json",
  "title": "devstate config v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["services"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "setup": {
      "$ref": "#/$defs/commandMap"
    },
    "checks": {
      "$ref": "#/$defs/commandMap"
    },
    "services": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/id"
      },
      "additionalProperties": {
        "$ref": "#/$defs/service"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cmd"],
      "properties": {
        "cmd": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "$ref": "#/$defs/stringMap"
        }
      }
    },
    "commandMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/id"
      },
      "additionalProperties": {
        "$ref": "#/$defs/command"
      }
    },
    "logProbe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["log"],
      "properties": {
        "log": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "httpProbe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["http"],
      "properties": {
        "http": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599,
          "default": 200
        }
      }
    },
    "eventProbe": {
      "oneOf": [
        {
          "$ref": "#/$defs/logProbe"
        },
        {
          "$ref": "#/$defs/httpProbe"
        }
      ]
    },
    "events": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": {
          "$ref": "#/$defs/logProbe"
        },
        "ready": {
          "$ref": "#/$defs/eventProbe"
        },
        "run": {
          "$ref": "#/$defs/eventProbe"
        },
        "pass": {
          "$ref": "#/$defs/eventProbe"
        },
        "fail": {
          "$ref": "#/$defs/eventProbe"
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cmd"],
      "properties": {
        "cmd": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "$ref": "#/$defs/stringMap"
        },
        "events": {
          "$ref": "#/$defs/events"
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    }
  }
}
